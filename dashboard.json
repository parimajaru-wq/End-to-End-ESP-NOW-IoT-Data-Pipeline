                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "afliiyw9qvfuoa"
                      },
                      "spec": {
                        "query": "from(bucket: \"ESP32\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"IoTFun_final\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp\" or r[\"_field\"] == \"pres\" or r[\"_field\"] == \"alti\")\n  // 1. รวมชื่อ Node กับชื่อ Field เข้าด้วยกัน\n  |> map(fn: (r) => ({ r with _field: r.node_name + \"_\" + r._field }))\n  // 2. Pivot โดยใช้แค่ _time เพื่อให้ทุก Node มาอยู่ในแถวเวลาเดียวกัน\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  // 3. [จุดสำคัญ] ตัดคอลัมน์ Metadata ที่ทำให้หัวตารางรกทิ้งไป\n  |> drop(columns: [\"device_id\", \"node_name\", \"_measurement\", \"_start\", \"_stop\"]) \n  |> sort(columns: [\"_time\"], desc: true)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
