      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "BMP280",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
